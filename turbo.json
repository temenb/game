{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    }
  },
  "pipeline": {
    "dev": {
      "env": [
        "GRPC_PORT",
        "HTTP_PORT",
        "JWT_ACCESS_SECRET",
        "JWT_REFRESH_SECRET",
        "SERVICE_*",
        "RABBIT_*"
      ]
    }
  }
}
