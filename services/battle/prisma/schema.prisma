generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CellValue {
  X
  O
  EMPTY
}

enum Status {
  New
  Active
  Finished
}

model Battle {
  id        String   @id @default(uuid())
  cells     CellValue[]
  status    Status
  Winner    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
